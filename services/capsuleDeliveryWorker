  const title = htmlEscape(
    safeText(data.title || data.subject, '一封來自過去的信')
  );
  const content = plainTextToHtml(
    data.content || data.text || data.previewLine || ''
  );
  const senderName = htmlEscape(
    safeText(data.senderName || data.ownerName, 'Akasha Cube')
  );
  const recipientName = htmlEscape(safeText(data.recipientName, '你'));
  const openDate = formatDate(resolveSendDate(data));
  const appUrl = safeText(process.env.AKASHA_APP_URL, DEFAULT_APP_URL);
  const coverImageUrl = safeText(
    data.coverImageUrl || data.photoUrl || data.attachmentImageUrl,
    ''
  );
  const audioUrl = safeText(data.audioUrl, '');
  const videoUrl = safeText(data.videoUrl, '');

  const imageBlock = coverImageUrl
    ? `<div style="margin:22px 0"><img src="${htmlEscape(
        coverImageUrl
      )}" alt="capsule image" style="width:100%;max-width:520px;border-radius:18px;display:block"/></div>`
    : '';

  const mediaBlock = [
    audioUrl
      ? `<p><a href="${htmlEscape(
          audioUrl
        )}" style="color:#b66b2b">聽這段語音</a></p>`
      : '',
    videoUrl
      ? `<p><a href="${htmlEscape(
          videoUrl
        )}" style="color:#b66b2b">看這段影片</a></p>`
      : '',
  ].join('');

  return `
  <!doctype html>
  <html>
  <body style="margin:0;padding:0;background:#120c08;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#3e2b22">
    <div style="max-width:640px;margin:0 auto;padding:28px 18px">
      <div style="background:#fff4df;border-radius:28px;padding:30px 24px;border:1px solid #e8c99d;box-shadow:0 18px 60px rgba(0,0,0,.28)">
        <p style="margin:0 0 10px;color:#9a6a35;font-weight:700;letter-spacing:.08em;font-size:12px;text-transform:uppercase">Akasha Cube · Time Capsule</p>
        <h1 style="margin:0;color:#3a2417;font-size:30px;line-height:1.18">${title}</h1>
        <p style="margin:12px 0 0;color:#7b5b3c;font-size:14px;line-height:1.6">${senderName} 在 ${openDate} 留給 ${recipientName} 的一封信。</p>
        ${imageBlock}
        <div style="margin-top:24px;padding:22px;border-radius:22px;background:#f7e2bf;border:1px solid rgba(90,55,20,.14);font-size:16px;line-height:1.85;color:#4b3324">
          ${content}
        </div>
        ${
          mediaBlock
            ? `<div style="margin-top:20px;font-size:15px">${mediaBlock}</div>`
            : ''
        }
        <div style="margin-top:28px;padding-top:18px;border-top:1px solid rgba(90,55,20,.14);color:#8b6746;font-size:13px;line-height:1.6">
          這封信由 Akasha Cube 在約定的時間送達。<br/>
          <a href="${htmlEscape(
            appUrl
          )}" style="color:#b66b2b;text-decoration:none;font-weight:700">Open Akasha Cube</a>
        </div>
      </div>
      <p style="text-align:center;color:#b59c7b;font-size:12px;margin-top:18px">Capsule ID ${htmlEscape(
        capsuleId
      )}</p>
    </div>
  </body>
  </html>`;
}

function buildCapsuleEmailText({ data }) {
  const title = safeText(
    data.title || data.subject,
    '一封來自過去的信'
  );
  const content = safeText(
    data.content || data.text || data.previewLine,
    '這封信沒有留下文字，但它帶著一段被保存的心意。'
  );
  const senderName = safeText(
    data.senderName || data.ownerName,
    'Akasha Cube'
  );
  const recipientName = safeText(data.recipientName, '你');
  const openDate = formatDate(resolveSendDate(data));

  return `${title}\n\n${senderName} 在 ${openDate} 留給 ${recipientName} 的一封信。\n\n${content}\n\nAkasha Cube`;
}

async function sendEmailWithResend({ to, subject, html, text }) {
  const apiKey = process.env.RESEND_API_KEY;
  if (!apiKey) throw new Error('RESEND_API_KEY is missing');

  const from = process.env.CAPSULE_FROM_EMAIL || DEFAULT_FROM;

  const response = await axios.post(
    'https://api.resend.com/emails',
    { from, to, subject, html, text },
    {
      headers: {
        Authorization: `Bearer ${apiKey}`,
        'Content-Type': 'application/json',
      },
      timeout: 20000,
    }
  );

  return response.data;
}

function errorMessage(error) {
  if (error?.response?.data) {
    return JSON.stringify(error.response.data).slice(0, 900);
  }
  return String(error?.message || error).slice(0, 900);
}

function classifyDeliveryError(error) {
  const statusCode = Number(error?.response?.status || 0);
  const code = String(error?.code || '').toUpperCase();
  const message = errorMessage(error).toLowerCase();

  if (
    message.includes('recipientemail is missing') ||
    message.includes('recipient email is missing')
  ) {
    return {
      permanent: true,
      reason: 'recipient_email_missing',
      statusCode,
    };
  }

  if (
    message.includes('recipientemail is invalid') ||
    message.includes('invalid email') ||
    message.includes('email address is invalid')
  ) {
    return {
      permanent: true,
      reason: 'recipient_email_invalid',
      statusCode,
    };
  }

  if ([400, 401, 403, 404, 405, 409, 410, 413, 415, 422].includes(statusCode)) {
    return {
      permanent: true,
      reason: `provider_http_${statusCode}`,
      statusCode,
    };
  }

  if ([408, 425, 429, 500, 502, 503, 504].includes(statusCode)) {
    return {
      permanent: false,
      reason: `provider_http_${statusCode}`,
      statusCode,
    };
  }

  if (
    ['ECONNABORTED', 'ECONNRESET', 'ETIMEDOUT', 'EAI_AGAIN', 'ENOTFOUND'].includes(
      code
    )
  ) {
    return {
      permanent: false,
      reason: code.toLowerCase(),
      statusCode,
    };
  }

  if (message.includes('timeout') || message.includes('temporarily unavailable')) {
    return {
      permanent: false,
      reason: 'temporary_provider_error',
      statusCode,
    };
  }

  if (statusCode >= 400 && statusCode < 500) {
    return {
      permanent: true,
      reason: `provider_http_${statusCode}`,
      statusCode,
    };
  }

  return {
    permanent: false,
    reason: 'unknown_retryable_error',
    statusCode,
  };
}

async function markCapsuleSending(docRef) {
  await docRef.set(
    {
      status: 'sending',
      deliveryStatus: 'sending',
      emailStatus: 'sending',
      emailAttemptCount: admin.firestore.FieldValue.increment(1),
      lastEmailAttemptAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    },
    { merge: true }
  );
}

async function markCapsuleSent(docRef, result) {
  await docRef.set(
    {
      status: 'sent',
      deliveryStatus: 'sent',
      emailStatus: 'sent',
      emailProvider: 'resend',
      emailProviderId: result?.id || '',
      sentAt: admin.firestore.FieldValue.serverTimestamp(),
      deliveredAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
      lastError: '',
      permanentFailureReason: '',
    },
    { merge: true }
  );
}

async function markCapsuleRetry(docRef, error, attemptCount, classification) {
  await docRef.set(
    {
      status: 'pending',
      deliveryStatus: 'failed',
      emailStatus: 'retry',
      lastError: errorMessage(error),
      lastFailureReason: classification.reason,
      lastFailureStatusCode: classification.statusCode || null,
      emailAttemptCount: attemptCount,
      lastFailedAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    },
    { merge: true }
  );
}

async function markCapsulePermanentFailed(
  docRef,
  error,
  attemptCount,
  classification
) {
  await docRef.set(
    {
      deliveryStatus: 'failed',
      emailStatus: 'permanent_failed',
      lastError: errorMessage(error),
      permanentFailureReason: classification.reason,
      lastFailureStatusCode: classification.statusCode || null,
      emailAttemptCount: attemptCount,
      permanentlyFailedAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    },
    { merge: true }
  );
}

async function writeDeliveryLog({
  capsuleId,
  status,
  recipientEmail,
  result,
  error,
  attemptCount,
  failureReason,
}) {
  await db.collection('email_delivery_logs').add({
    capsuleId,
    status,
    recipientEmail: recipientEmail || '',
    provider: 'resend',
    providerResult: result || null,
    error: error ? errorMessage(error) : '',
    attemptCount: Number(attemptCount || 0),
    failureReason: failureReason || '',
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
  });
}

async function sendCapsuleNow(doc) {
  const data = doc.data() || {};
  const capsuleId = doc.id;
  const docRef = db.collection('capsules').doc(capsuleId);
  const recipientEmail = safeText(data.recipientEmail, '');
  const previousAttemptCount = currentAttemptCount(data);
  const maxAttempts = maxEmailAttempts();

  if (isAlreadyCompleted(data)) {
    return {
      capsuleId,
      status: 'skipped',
      reason: 'already_completed',
    };
  }

  if (previousAttemptCount >= maxAttempts) {
    const error = new Error(
      `Maximum email attempts reached (${previousAttemptCount}/${maxAttempts})`
    );
    const classification = {
      permanent: true,
      reason: 'max_attempts_reached',
      statusCode: 0,
    };

    await markCapsulePermanentFailed(
      docRef,
      error,
      previousAttemptCount,
      classification
    );
    await writeDeliveryLog({
      capsuleId,
      status: 'permanent_failed',
      recipientEmail,
      error,
      attemptCount: previousAttemptCount,
      failureReason: classification.reason,
    });

    return {
      capsuleId,
      status: 'permanent_failed',
      error: error.message,
    };
  }

  if (!recipientEmail) {
    const error = new Error('recipientEmail is missing');
    const classification = {
      permanent: true,
      reason: 'recipient_email_missing',
      statusCode: 0,
    };

    await markCapsulePermanentFailed(
      docRef,
      error,
      previousAttemptCount,
      classification
    );
    await writeDeliveryLog({
      capsuleId,
      status: 'permanent_failed',
      recipientEmail: '',
      error,
      attemptCount: previousAttemptCount,
      failureReason: classification.reason,
    });

    return {
      capsuleId,
      status: 'permanent_failed',
      error: error.message,
    };
  }

  if (!isValidEmail(recipientEmail)) {
    const error = new Error('recipientEmail is invalid');
    const classification = {
      permanent: true,
      reason: 'recipient_email_invalid',
      statusCode: 0,
    };

    await markCapsulePermanentFailed(
      docRef,
      error,
      previousAttemptCount,
      classification
    );
    await writeDeliveryLog({
      capsuleId,
      status: 'permanent_failed',
      recipientEmail,
      error,
      attemptCount: previousAttemptCount,
      failureReason: classification.reason,
    });

    return {
      capsuleId,
      status: 'permanent_failed',
      error: error.message,
    };
  }

  const subject = safeText(
    data.emailSubject || data.title || data.subject,
    '一封來自過去的時間膠囊'
  );
  const html = buildCapsuleEmailHtml({ capsuleId, data });
  const text = buildCapsuleEmailText({ data });
  const attemptCount = previousAttemptCount + 1;

  await markCapsuleSending(docRef);

  try {
    const result = await sendEmailWithResend({
      to: recipientEmail,
      subject,
      html,
      text,
    });

    await markCapsuleSent(docRef, result);
    await writeDeliveryLog({
      capsuleId,
      status: 'sent',
      recipientEmail,
      result,
      attemptCount,
    });

    return {
      capsuleId,
      status: 'sent',
      providerResult: result,
    };
  } catch (error) {
    const classification = classifyDeliveryError(error);
    const reachedLimit = attemptCount >= maxAttempts;
    const permanentlyFailed = classification.permanent || reachedLimit;
    const failureReason = reachedLimit
      ? 'max_attempts_reached'
      : classification.reason;

    if (permanentlyFailed) {
      await markCapsulePermanentFailed(
        docRef,
        error,
        attemptCount,
        {
          ...classification,
          permanent: true,
          reason: failureReason,
        }
      );
    } else {
      await markCapsuleRetry(
        docRef,
        error,
        attemptCount,
        classification
      );
    }

    await writeDeliveryLog({
      capsuleId,
      status: permanentlyFailed ? 'permanent_failed' : 'retry',
      recipientEmail,
      error,
      attemptCount,
      failureReason,
    });

    throw error;
  }
}

async function findDueCapsules(limit = 40) {
  const now = nowDate();
  const statuses = ['queued', 'pending', 'email_queued', 'retry'];

  const snap = await db
    .collection('capsules')
    .where('emailStatus', 'in', statuses)
    .limit(limit)
    .get();

  return snap.docs.filter((doc) => isDueSendOnDay(doc.data(), now));
}

async function processDueCapsules(options = {}) {
  const limit = Number(
    options.limit || process.env.EMAIL_QUEUE_BATCH_SIZE || 40
  );
  const docs = await findDueCapsules(limit);
  const results = [];

  for (const doc of docs) {
    try {
      const result = await sendCapsuleNow(doc);
      results.push(result);
    } catch (error) {
      results.push({
        capsuleId: doc.id,
        status: 'failed',
        error: error?.response?.data || error?.message || String(error),
      });
    }
  }

  return {
    checkedAt: new Date().toISOString(),
    dueCount: docs.length,
    results,
  };
}

async function sendOneCapsule(capsuleId) {
  const doc = await db.collection('capsules').doc(capsuleId).get();
  if (!doc.exists) throw new Error('Capsule not found');
  return sendCapsuleNow(doc);
}

function logQueueResult(result) {
  const counts = result.results.reduce(
    (summary, item) => {
      const key = item.status || 'unknown';
      summary[key] = (summary[key] || 0) + 1;
      return summary;
    },
    {}
  );

  console.log(
    '[EmailQueue] processed',
    JSON.stringify({
      checkedAt: result.checkedAt,
      dueCount: result.dueCount,
      counts,
      results: result.results,
    })
  );
}

function startEmailQueueWorker() {
  if (workerStarted) return;

  if (
    String(process.env.EMAIL_WORKER_ENABLED || 'true').toLowerCase() ===
    'false'
  ) {
    console.log('[EmailQueue] worker disabled');
    return;
  }

  workerStarted = true;
  const intervalMs = Number(
    process.env.EMAIL_QUEUE_INTERVAL_MS || 60000
  );

  console.log(
    `[EmailQueue] worker started interval=${intervalMs}ms maxAttempts=${maxEmailAttempts()}`
  );

  const run = async () => {
    if (workerBusy) return;

    workerBusy = true;
    try {
      const result = await processDueCapsules();
      if (result.dueCount > 0) {
        logQueueResult(result);
      }
    } catch (error) {
      console.error(
        '[EmailQueue] worker error:',
        error?.response?.data || error?.message || error
      );
    } finally {
      workerBusy = false;
    }
  };

  setTimeout(run, 5000);
  setInterval(run, intervalMs);
}

module.exports = {
  processDueCapsules,
  sendOneCapsule,
  startEmailQueueWorker,
  isDueSendOnDay,
};
