const axios = require('axios');
const admin = require('firebase-admin');

function getServiceAccountFromEnv() {
  const raw = process.env.FIREBASE_SERVICE_ACCOUNT;
  if (!raw) {
    throw new Error('FIREBASE_SERVICE_ACCOUNT is missing');
  }

  const parsed = JSON.parse(raw);
  if (parsed.private_key) {
    parsed.private_key = parsed.private_key.replace(/\\n/g, '\n');
  }
  return parsed;
}

function initFirebaseAdmin() {
  if (!admin.apps.length) {
    admin.initializeApp({
      credential: admin.credential.cert(getServiceAccountFromEnv()),
    });
  }
  return admin.firestore();
}

const db = initFirebaseAdmin();

const DEFAULT_FROM = 'Akasha Cube <onboarding@resend.dev>';
const DEFAULT_APP_URL = 'https://akashacube.vip';
const DEFAULT_MAX_EMAIL_ATTEMPTS = 3;

let workerStarted = false;
let workerBusy = false;

function nowDate() {
  return new Date();
}

function toDate(value) {
  if (!value) return null;
  if (value instanceof Date) return value;
  if (typeof value.toDate === 'function') return value.toDate();
  if (typeof value === 'string') {
    const parsed = new Date(value);
    return Number.isNaN(parsed.getTime()) ? null : parsed;
  }
  return null;
}

function formatDate(date) {
  if (!date) return '未設定日期';
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}/${m}/${d}`;
}

function safeText(value, fallback = '') {
  const text = String(value ?? '').trim();
  return text || fallback;
}

function htmlEscape(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function capsuleMode(data) {
  return String(
    data.capsuleMode || data.mode || data.creationMode || 'send_on_day'
  ).toLowerCase();
}

function resolveSendDate(data) {
  return (
    toDate(data.sendAt) ||
    toDate(data.deliveryDate) ||
    toDate(data.scheduledAt) ||
    toDate(data.triggerDate)
  );
}

function maxEmailAttempts() {
  const configured = Number(process.env.EMAIL_MAX_ATTEMPTS);
  if (Number.isFinite(configured) && configured >= 1) {
    return Math.floor(configured);
  }
  return DEFAULT_MAX_EMAIL_ATTEMPTS;
}

function currentAttemptCount(data) {
  const count = Number(data.emailAttemptCount || 0);
  return Number.isFinite(count) && count > 0 ? Math.floor(count) : 0;
}

function isValidEmail(value) {
  const email = safeText(value, '');
  if (!email || email.length > 320) return false;
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

function isAlreadyCompleted(data) {
  const status = String(data.status || '').toLowerCase();
  const deliveryStatus = String(data.deliveryStatus || '').toLowerCase();
  const emailStatus = String(data.emailStatus || '').toLowerCase();

  return (
    ['sent', 'opened', 'delivered', 'cancelled', 'deleted'].includes(status) ||
    ['sent', 'delivered'].includes(deliveryStatus) ||
    ['sent', 'delivered', 'permanent_failed'].includes(emailStatus)
  );
}

function isDueSendOnDay(data, now = nowDate()) {
  const mode = capsuleMode(data);
  if (mode !== 'send_on_day' && mode !== 'sendonday' && mode !== 'date') {
    return false;
  }

  if (isAlreadyCompleted(data)) return false;

  const emailStatus = String(data.emailStatus || '').toLowerCase();
  if (!['queued', 'pending', 'email_queued', 'retry'].includes(emailStatus)) {
    return false;
  }

  if (currentAttemptCount(data) >= maxEmailAttempts()) return false;

  const date = resolveSendDate(data);
  if (!date) return false;
  return date.getTime() <= now.getTime();
}

function plainTextToHtml(text) {
  const safe = htmlEscape(
    text || '這封信沒有留下文字，但它帶著一段被保存的心意。'
  );
  return safe.replace(/\n/g, '<br/>');
}

